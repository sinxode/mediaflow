# MediaFlow Backend Configuration Setup Template
# Copy this file to '.env' or '.env.local' and fill in your actual values.

# Central Supabase Client Endpoint Configurations
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anonymous-public-key-token

# Toggle mock data layer (true by default for local offline development)
VITE_USE_MOCK=true
